# Supabase Configuration
# Required: Get these from your Supabase project settings
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alternative naming (for compatibility)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
SUPABASE_SECRET_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:9002

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Square Configuration (for booking payments)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APP_ID=your_square_app_id
SQUARE_ENVIRONMENT=sandbox

# Resend Configuration (for transactional emails)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_AUDIENCE_ID=your_audience_id

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Database Configuration (Vercel Postgres)
POSTGRES_URL=postgres://default:your-password@host/database
POSTGRES_PRISMA_URL=postgres://default:your-password@host/database?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://default:your-password@host/database
POSTGRES_USER=default
POSTGRES_HOST=your-postgres-host
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DATABASE=your-database-name

# Additional Configuration
SUPABASE_JWT_SECRET=your-jwt-secret
PAYLOAD_SECRET=your-payload-secret
CRON_SECRET=your-cron-secret
AI_GATEWAY_API_KEY=your-ai-gateway-key

# Optional: For debugging
NODE_ENV=development
DEBUG_DB=false
