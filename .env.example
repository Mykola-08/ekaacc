# ============================================================================
# EKA Account — Environment Variables Reference
# ============================================================================
# Copy this file to .env.local and fill in your real values.
#   cp .env.example .env.local
#
# Variables marked [PUBLISHABLE] are safe for the browser (NEXT_PUBLIC_*).
# Variables marked [SECRET] must NEVER be exposed to the client.
# Variables marked [CONFIG] are optional tuning knobs.
#
# Many secrets also support storage in the Supabase `app_config` table
# (with RLS). The app checks app_config first, then falls back to env.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_URL=http://localhost:9002                   # [PUBLISHABLE] App base URL
NEXT_PUBLIC_APP_URL=http://localhost:9002                # [PUBLISHABLE] Used in emails & referer headers

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co      # [PUBLISHABLE] Project URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...        # [PUBLISHABLE] Anon / publishable key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...               # [PUBLISHABLE] Alias for publishable key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...                   # [SECRET]      Service role key
SUPABASE_SECRET_KEY=eyJhbGci...                         # [SECRET]      Legacy alias
POSTGRES_URL=postgresql://postgres:...@...supabase.co   # [SECRET]      Direct DB connection string

# ── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...          # [PUBLISHABLE] Stripe.js public key
STRIPE_SECRET_KEY=sk_test_...                           # [SECRET]      Stripe API secret
STRIPE_WEBHOOK_SECRET=whsec_...                         # [SECRET]      Webhook signing secret

# ── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                                   # [SECRET]      Resend API key
RESEND_AUDIENCE_ID=                                     # [SECRET]      Optional audience/contact list

# ── AI / LLMs ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                                   # [SECRET]      OpenAI API key
OPENROUTER_API_KEY=sk-or-...                            # [SECRET]      OpenRouter API key

# ── Google ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com       # [SECRET]      OAuth client ID
GOOGLE_CLIENT_SECRET=GOCSPX-...                         # [SECRET]      OAuth client secret
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account"}  # [SECRET]      Service account JSON

# ── Zoom ─────────────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=                                         # [SECRET]      OAuth client ID
ZOOM_CLIENT_SECRET=                                     # [SECRET]      OAuth client secret
ZOOM_ACCOUNT_ID=                                        # [SECRET]      Account ID

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                                     # [SECRET]      Bot API token
TELEGRAM_SECRET_TOKEN=                                  # [SECRET]      Webhook secret

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io            # [SECRET]      Redis REST endpoint
UPSTASH_REDIS_REST_TOKEN=AXxx...                        # [SECRET]      Redis auth token

# ── Security / Admin Tokens ──────────────────────────────────────────────────
CRON_SECRET=                                            # [SECRET]      Cron endpoint auth
ADMIN_PROMOTE_TOKEN=                                    # [SECRET]      Admin promotion endpoint
BOOKING_TOKEN_SECRET=                                   # [SECRET]      Booking token signing
UNSUBSCRIBE_SECRET=                                     # [SECRET]      Email unsubscribe signing

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=120                             # [CONFIG]      Requests per window
RATE_LIMIT_WINDOW_SECONDS=60                            # [CONFIG]      Window duration (seconds)
ACCESS_TOKEN_RATE_LIMIT=40                              # [CONFIG]      /api/auth/access-token limit
ACCESS_TOKEN_REFRESH_THRESHOLD_SECONDS=60               # [CONFIG]      Auto-refresh before expiry
BOT_PROTECTION_ENABLED=false                            # [CONFIG]      UA-based bot blocking
# BOT_PROTECTION_BLOCK_LIST=                            # [CONFIG]      Comma-separated UA substrings

# ── Config System ────────────────────────────────────────────────────────────
CONFIG_DB_ENABLED=1                                     # [CONFIG]      Enable app_config table
# CONFIG_DB_PRELOAD=0                                   # [CONFIG]      Preload all configs on start

# ── Logging ──────────────────────────────────────────────────────────────────
# NEXT_ENABLE_REMOTE_LOGGING=false                      # [CONFIG]      Remote log shipping
# NEXT_ENABLE_CONSOLE_LOGGING=true                      # [CONFIG]      Force console logs in prod
# NEXT_LOG_LEVEL=DEBUG                                  # [CONFIG]      DEBUG | INFO | WARN | ERROR
