# =============================================================================
# Environment Variables for Ekaacc
# =============================================================================
# Copy this file to .env.local and fill in the values
# For Vercel, set these in the Vercel Dashboard > Project Settings > Environment Variables

# =============================================================================
# Supabase Configuration
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# =============================================================================
# Database (PostgreSQL via Supabase)
# =============================================================================
POSTGRES_URL=postgres://postgres.your-project:password@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_PRISMA_URL=postgres://postgres.your-project:password@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project:password@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_USER=postgres
POSTGRES_HOST=aws-1-eu-west-3.pooler.supabase.com
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=postgres

# =============================================================================
# Payload CMS (Web App)
# =============================================================================
PAYLOAD_SECRET=your-payload-secret-min-32-chars

# =============================================================================
# Vercel Blob Storage
# =============================================================================
BLOB_READ_WRITE_TOKEN=vercel_blob_your_token

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_AUDIENCE_ID=your-audience-id

# =============================================================================
# Stripe (Payments)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# =============================================================================
# Square (Alternative Payments)
# =============================================================================
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_APP_ID=your-square-app-id
SQUARE_ENVIRONMENT=sandbox

# =============================================================================
# Push Notifications (Web Push)
# =============================================================================
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# =============================================================================
# AI Services
# =============================================================================
AI_GATEWAY_API_KEY=your-ai-gateway-key
OPENAI_API_KEY=your-openai-key

# =============================================================================
# Application URLs
# =============================================================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# =============================================================================
# Cron Jobs
# =============================================================================
CRON_SECRET=your-cron-secret

# =============================================================================
# Vercel (Automatically set by Vercel)
# =============================================================================
# VERCEL_URL - Automatically set
# VERCEL_ENV - Automatically set (production, preview, development)
