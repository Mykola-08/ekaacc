# Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env.local or .env.production to version control

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Node environment (development, production, test)
NODE_ENV=development

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:9002
NEXT_PUBLIC_API_URL=http://localhost:9002/api

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public, safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (KEEP SECRET - server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase JWT Secret (for session management)
SUPABASE_JWT_SECRET=your_jwt_secret

# ============================================
# STRIPE CONFIGURATION (Payment Processing)
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development (sk_test_, pk_test_)
# Use live keys for production (sk_live_, pk_live_)

# Stripe Secret Key (KEEP SECRET - server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Publishable Key (public, safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret (for webhook signature verification)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# SQUARE CONFIGURATION (Booking & Payments)
# ============================================
# Get these from: https://developer.squareup.com/apps

# Square Access Token (KEEP SECRET)
SQUARE_ACCESS_TOKEN=your_square_access_token

# Square Environment (sandbox or production)
SQUARE_ENVIRONMENT=sandbox

# Square Application ID
SQUARE_APPLICATION_ID=your_square_application_id

# Square Location ID (for bookings)
SQUARE_LOCATION_ID=your_square_location_id

# Square Webhook Signature Key (for webhook verification)
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key

# Square Appointments Integration (Alpha Features)
NEXT_PUBLIC_SQUARE_APPOINTMENTS_ENABLED=false
NEXT_PUBLIC_SQUARE_SYNC_ENABLED=false
NEXT_PUBLIC_SQUARE_WEBHOOKS_ENABLED=false
NEXT_PUBLIC_SQUARE_IMPORT_ENABLED=false

# Square API Configuration
SQUARE_API_VERSION=2025-01-23
SQUARE_SYNC_BATCH_SIZE=50
SQUARE_SYNC_INTERVAL_HOURS=1

# ============================================
# AI SERVICES CONFIGURATION
# ============================================

# OpenAI API Key (for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic API Key (for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Google AI API Key (for Gemini models)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# For sending transactional emails

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# Email sender address
EMAIL_FROM=noreply@your-domain.com

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_very_long_random_secret_string_minimum_32_characters

# NextAuth URL (should match your app URL)
NEXTAUTH_URL=http://localhost:9002

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry DSN (for error tracking)
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Google Analytics Measurement ID
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog Analytics (Optional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features for gradual rollout

# AI Features
FEATURE_FLAG_AI_INSIGHTS=true
FEATURE_FLAG_AI_CHAT=true

# Community Features
FEATURE_FLAG_COMMUNITY=true
FEATURE_FLAG_COMMUNITY_POSTS=true

# Booking Features
FEATURE_FLAG_BOOKINGS=true
FEATURE_FLAG_THERAPIST_BOOKING=true

# Payment Features
FEATURE_FLAG_SUBSCRIPTIONS=true
FEATURE_FLAG_WALLET=true

# Social Features
FEATURE_FLAG_REFERRALS=true
FEATURE_FLAG_LOYALTY_PROGRAM=true

# ============================================
# RATE LIMITING & SECURITY
# ============================================

# Rate limit for API endpoints (requests per minute)
RATE_LIMIT_API=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_AI=20

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:9002,http://localhost:3000

# ============================================
# DATABASE CONFIGURATION (Advanced)
# ============================================
# Usually not needed as Supabase handles this

# Direct database connection string (if needed)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# STORAGE CONFIGURATION
# ============================================

# AWS S3 (for file uploads - optional, Supabase Storage is default)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Supabase Storage bucket (default)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=avatars

# ============================================
# LOGGING & DEBUGGING
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode (shows more detailed logs)
DEBUG=false

# Enable SQL query logging
LOG_SQL_QUERIES=false

# ============================================
# WEBHOOK ENDPOINTS
# ============================================

# Your webhook endpoints for external services
WEBHOOK_BASE_URL=http://localhost:9002/api/webhooks

# Stripe webhook endpoint
STRIPE_WEBHOOK_URL=${WEBHOOK_BASE_URL}/stripe

# Square webhook endpoint
SQUARE_WEBHOOK_URL=${WEBHOOK_BASE_URL}/square

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Calendly (for scheduling integrations)
CALENDLY_API_KEY=your_calendly_api_key

# Zoom (for video sessions)
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# DEVELOPMENT TOOLS
# ============================================

# Next.js Telemetry (disable for privacy)
NEXT_TELEMETRY_DISABLED=1

# Enable bundle analyzer
ANALYZE=false

# Enable experimental features
NEXT_EXPERIMENTAL_TURBOPACK=false

# ============================================
# TESTING CONFIGURATION
# ============================================

# Test database URL (for integration tests)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/test_db

# Test Stripe key
TEST_STRIPE_SECRET_KEY=sk_test_your_test_key

# Playwright configuration
PLAYWRIGHT_BASE_URL=http://localhost:9002
PLAYWRIGHT_HEADLESS=true

# ============================================
# NOTES
# ============================================

# 1. Generate secure secrets with:
#    openssl rand -base64 32

# 2. Never commit this file with real values
#    Add .env.local to .gitignore

# 3. For production, use environment-specific files:
#    - .env.development
#    - .env.production
#    - .env.test

# 4. Use a secrets manager for production:
#    - Vercel: Use environment variables in dashboard
#    - AWS: Use AWS Secrets Manager
#    - Azure: Use Azure Key Vault
#    - GCP: Use Secret Manager

# 5. Rotate API keys regularly (every 90 days recommended)

# 6. Use different keys for development, staging, and production

# 7. Monitor API usage and set up alerts for unusual activity

# 8. Document which services require which keys in your team wiki
