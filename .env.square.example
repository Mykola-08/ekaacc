# Square Appointments Integration Configuration
# Add these to your .env file to enable Square Appointments integration

# Basic Configuration
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_ENV=Sandbox # or Production
SQUARE_LOCATION_ID=your_location_id_here # Optional, leave empty for all locations

# Webhook Configuration (Required for real-time sync)
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_here

# Feature Flags (Control alpha features)
NEXT_PUBLIC_SQUARE_APPOINTMENTS_ENABLED=false
NEXT_PUBLIC_SQUARE_SYNC_ENABLED=false
NEXT_PUBLIC_SQUARE_WEBHOOKS_ENABLED=false
NEXT_PUBLIC_SQUARE_IMPORT_ENABLED=false

# API Configuration
SQUARE_API_VERSION=2025-01-23

# Sync Configuration
SQUARE_SYNC_BATCH_SIZE=50
SQUARE_SYNC_INTERVAL_HOURS=1

# Webhook URL (Set this in Square Dashboard)
# https://your-domain.com/api/webhooks/square

# Required OAuth Scopes for Square Appointments:
# - APPOINTMENTS_READ
# - APPOINTMENTS_WRITE
# - APPOINTMENTS_ALL_READ
# - APPOINTMENTS_ALL_WRITE
# - CUSTOMERS_READ
# - CUSTOMERS_WRITE
# - MERCHANT_PROFILE_READ

# Getting Started:
# 1. Create a Square Developer account at https://developer.squareup.com
# 2. Create a new application
# 3. Get your Application ID and Access Token
# 4. Configure webhooks in the Square Dashboard
# 5. Set up your webhook endpoint URL
# 6. Test in Sandbox mode first
# 7. Switch to Production when ready