{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Application",
			"type": "shell",
			"command": "npm run build",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Start Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": [
				"$next-tsc"
			]
		},
		{
			"label": "Install Plate",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"yes | npx shadcn@latest add https://platejs.org/r/editor-ai --overwrite"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Install Plate PWSH",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-Command",
				"while($true){\"y\"} | npx shadcn@latest add https://platejs.org/r/editor-ai --overwrite"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}