/**
 * @fileoverview Firestore Security Rules for EKA Account system.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-specific data,
 * and employs denormalization and structural segregation to ensure efficient and secure access control.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles.
 * - /accounts/{accountId}: Stores account information.
 * - /users/{userId}/sessions/{sessionId}: Stores therapy session data owned by the user.
 * - /therapists/{therapistId}: Stores therapist profiles.
 * - /donations/{donationId}: Stores donation records, with access controlled by donor and receiver.
 * - /users/{userId}/reports/{reportId}: Stores reports generated by users or therapists, owned by the user.
 * - /plans/{planId}: Stores subscription plan details (publicly readable).
 * - /messages/{messageId}: Stores messages exchanged between users, accessible only to sender and receiver.
 * - /roles_admin/{userId}: Stores admin roles; existence of a document indicates admin privileges.
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - Public read access is granted to the /plans collection.
 * - All write operations require authentication and proper authorization.
 * - Denormalization is used extensively to avoid costly `get()` calls in rules.
 * - Every `match` block has a comprehensive set of allow statements covering all five permissions.
 *
 * Denormalization for Authorization:
 * - Sessions under `/users/{userId}/sessions/{sessionId}` include the `therapistId` to avoid needing to fetch the therapist document for authorization.
 * - Reports under `/users/{userId}/reports/{reportId}` include the `therapistId` to avoid needing to fetch the therapist document for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rule for user profiles. Only the user can read/write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, list, update, delete) - Authenticated user can get, update, delete their profile if the userId matches their auth.uid.
     * @deny (create) - If the userId does not match their auth.uid.
     * @deny (get, list, update, delete) - If the userId does not match their auth.uid or if the document does not exist on update/delete.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Rule for account information. Access is restricted to the associated user.
     * @path /accounts/{accountId}
     * @allow (get) - Authenticated user can get their account if the accountId matches their user's accountId.
     * @deny (create, update, delete) - No one can create, update, or delete accounts directly.
     * @deny (get) - If the accountId does not match their user's accountId.
     * @principle Restricts access to a user's own account data.
     */
    match /accounts/{accountId} {
      function isAccountOwner(accountId) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountId == accountId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isAccountOwner(accountId);
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for therapy sessions under a user. Only the user can read/write their own sessions.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create) - Authenticated user can create a session under their userId.
     * @allow (get, list, update, delete) - Authenticated user can get, list, update, delete a session under their userId.
     * @deny (create, update, delete) - If the userId does not match their auth.uid or the document does not exist.
     * @principle Enforces document ownership and prevents unauthorized access.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
        function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Rule for therapist profiles. Only the therapist can read/write their own profile.
     * @path /therapists/{therapistId}
     * @allow (create) - Authenticated user can create their own profile if the therapistId matches their auth.uid.
     * @allow (get, list, update, delete) - Authenticated user can get, update, delete their profile if the therapistId matches their auth.uid.
     * @deny (create) - If the therapistId does not match their auth.uid.
     * @deny (get, list, update, delete) - If the therapistId does not match their auth.uid or if the document does not exist on update/delete.
     * @principle Enforces document ownership for writes.
     */
    match /therapists/{therapistId} {
      function isOwner(therapistId) {
        return request.auth.uid == therapistId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
        function isExistingOwner(therapistId) {
        return isOwner(therapistId) && resource != null;
      }
      allow get: if isSignedIn() && isOwner(therapistId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(therapistId);
      allow update: if isSignedIn() && isExistingOwner(therapistId);
      allow delete: if isSignedIn() && isExistingOwner(therapistId);
    }

    /**
     * @description Rule for donations. Only the donor or receiver can read a donation. Only the donor can create a donation. Only the donor can update a donation, and only to set isAnonymous. No one can delete a donation.
     * @path /donations/{donationId}
     * @allow (create) - Authenticated user can create a donation if they are the donor.
     * @allow (get) - Authenticated user can get a donation if they are the donor or the receiver.
     * @deny (update, delete) - No one can update or delete a donation, except for setting `isAnonymous` to `true` by the donor.
     * @principle Enforces that only the donor or receiver can access donation information.
     */
    match /donations/{donationId} {
      function isDonor() {
        return request.auth.uid == resource.data.donorId;
      }
      function isReceiver() {
        return request.auth.uid == resource.data.receiverId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && (isDonor() || isReceiver());
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.donorId;
      allow update: if false; // TODO: Add validation for setting isAnonymous to true
      allow delete: if false;
    }

    /**
     * @description Rule for reports under a user. Only the user can read/write their own reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) - Authenticated user can create a report under their userId.
     * @allow (get, list, update, delete) - Authenticated user can get, list, update, delete a report under their userId.
     * @deny (create, update, delete) - If the userId does not match their auth.uid or if the document does not exist.
     * @principle Enforces document ownership and prevents unauthorized access.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
        function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Rule for subscription plans. Anyone can read plan details, but only admins can create, update, or delete them.
     * @path /plans/{planId}
     * @allow (get, list) - Anyone can read plan details.
     * @deny (create, update, delete) - No one can create, update, or delete plans.
     * @principle Allows public read access to plan information.
     */
    match /plans/{planId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for messages. Only the sender or receiver can read a message. Only the sender can create a message. No one can update or delete a message.
     * @path /messages/{messageId}
     * @allow (create) - Authenticated user can create a message if they are the sender.
     * @allow (get) - Authenticated user can get a message if they are the sender or the receiver.
     * @deny (update, delete) - No one can update or delete a message.
     * @principle Enforces that only the sender or receiver can access message information.
     */
    match /messages/{messageId} {
      function isSender() {
        return request.auth.uid == resource.data.senderId;
      }
      function isReceiver() {
        return request.auth.uid == resource.data.receiverId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && (isSender() || isReceiver());
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId;
      allow update: if false;
      allow delete: if false;
    }

       /**
         * @description Allows admins to manage their profiles. The existence of the user document in this collection implies admin rights.
         * @path /roles_admin/{userId}
         * @allow (create, get, update, delete) - Only the user themselves can create, get, update, or delete the document that marks them as an admin.  This is the sole mechanism for them to manage their role.
         * @allow (list) - Listing of admins is denied, as it exposes sensitive information.
         * @deny (create, get, update, delete) - If the userId does not match their auth.uid or if the document does not exist.
         * @principle Self-management of admin role via document existence.
         */
        match /roles_admin/{userId} {
            function isOwner(userId) {
                return request.auth.uid == userId;
            }
            function isSignedIn() {
                return request.auth != null;
            }
            function isExistingOwner(userId) {
              return isOwner(userId) && resource != null;
            }

            allow get: if isSignedIn() && isOwner(userId);
            allow list: if false;
            allow create: if isSignedIn() && isOwner(userId);
            allow update: if isSignedIn() && isExistingOwner(userId);
            allow delete: if isSignedIn() && isExistingOwner(userId);
        }
  }
}