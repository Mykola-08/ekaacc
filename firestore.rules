/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for private data,
 *              while allowing public read access to certain collections like `services` and `vipPlans`.
 *              It utilizes denormalization to simplify authorization logic and avoid costly `get()` calls.
 *
 * Data Structure:
 * - `/users/{userId}`: Stores user profiles. Only the user or an admin can access their own profile.
 * - `/users/{userId}/sessions/{sessionId}`: Stores therapy sessions for each user.
 *                                             Only the user or their therapist can access their session data.
 * - `/donations/{donationId}`: Stores donation data. `donorId` and `receiverId` are denormalized to a `members` map.
 *                                 Allows listing donations where the user is a donor or a receiver.
 * - `/users/{userId}/reports/{reportId}`: Stores reports for each user. The `therapistId` is included in each document.
 *                                          Therapists can access reports they created for their patients.
 * - `/messages/{messageId}`: Stores messages. `senderId` and `receiverId` are denormalized to a `members` map.
 *                               Allows listing messages where the user is a sender or receiver.
 * - `/users/{userId}/subscriptions/{subscriptionId}`: Stores subscription information for each user.
 * - `/services/{serviceId}`: Stores available therapy services. Publicly readable.
 * - `/vipPlans/{planId}`: Stores VIP subscription plan details. Publicly readable.
 *
 * Key Security Decisions:
 * - Strict user-ownership for data under `/users/{userId}`.
 * - Therapists can access reports they created for their patients.
 * - Public read access for `services` and `vipPlans` collections.
 * - Denormalization of `donorId`/`receiverId` and `senderId`/`receiverId` to `members` maps in `donations` and `messages` for efficient authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their profile.
     *        request.auth.uid == 'user123' and request.resource.data.id == 'user123'
     * @allow (get) User with ID 'user123' reads their profile.
     *        request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their profile.
     *        request.auth.uid == 'user123' and resource.data.id == 'user123'
     * @allow (delete) User with ID 'user123' deletes their profile.
     *        request.auth.uid == 'user123' and resource.data.id == 'user123'
     * @deny (create) User with ID 'user456' tries to create a profile for 'user123'.
     *       request.auth.uid == 'user456' and request.resource.data.id == 'user123'
     * @deny (get) User with ID 'user456' tries to read profile of 'user123'.
     *       request.auth.uid == 'user456'
     * @principle Enforces document ownership for writes. Restricts access to a user's own data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures therapy sessions for each user.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create) User with ID 'user123' creates a session.
     *        request.auth.uid == 'user123'
     * @allow (get) User with ID 'user123' reads their session.
     *        request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their session.
     *        request.auth.uid == 'user123'
     * @allow (delete) User with ID 'user123' deletes their session.
     *        request.auth.uid == 'user123'
     * @deny (create) User with ID 'user456' tries to create a session for 'user123'.
     *        request.auth.uid == 'user456'
     * @deny (get) User with ID 'user456' tries to read session of 'user123'.
     *        request.auth.uid == 'user456'
     * @principle Enforces document ownership for writes. Restricts access to a user's own data.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures donation data.
     * @path /donations/{donationId}
     * @allow (create) User with ID 'user123' creates a donation.
     *        request.auth.uid == 'user123'
     * @allow (get) User with ID 'user123' reads a donation if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @allow (update) User with ID 'user123' updates a donation if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @allow (delete) User with ID 'user123' deletes a donation if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @deny (create) User with ID 'user456' tries to create a donation without being authenticated.
     *        request.auth.uid == null
     * @deny (get) User with ID 'user456' tries to read donation without being a member.
     *        request.auth.uid == 'user456' and resource.data.members[request.auth.uid] == null
     * @principle Enforces document ownership for writes. Restricts access to members only.
     */
    match /donations/{donationId} {
      function isMember() {
        return resource.data.members[request.auth.uid] == true;
      }
      function isExistingMember() {
        return request.auth.uid != null && isMember() && resource != null;
      }
      allow get, list: if request.auth.uid != null && isMember();
      allow create: if request.auth.uid != null;
      allow update: if isExistingMember();
      allow delete: if isExistingMember();
    }

    /**
     * @description Secures reports for each user.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' creates a report.
     *        request.auth.uid == 'user123'
     * @allow (get) User with ID 'user123' reads their report.
     *        request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their report.
     *        request.auth.uid == 'user123'
     * @allow (delete) User with ID 'user123' deletes their report.
     *        request.auth.uid == 'user123'
     * @deny (create) User with ID 'user456' tries to create a report for 'user123'.
     *        request.auth.uid == 'user456'
     * @deny (get) User with ID 'user456' tries to read report of 'user123'.
     *        request.auth.uid == 'user456'
     * @principle Enforces document ownership for writes. Restricts access to a user's own data.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures messages.
     * @path /messages/{messageId}
     * @allow (create) User with ID 'user123' creates a message.
     *        request.auth.uid == 'user123'
     * @allow (get) User with ID 'user123' reads a message if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @allow (update) User with ID 'user123' updates a message if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @allow (delete) User with ID 'user123' deletes a message if they are a member.
     *        request.auth.uid == 'user123' and resource.data.members[request.auth.uid] == true
     * @deny (create) User with ID 'user456' tries to create a message without being authenticated.
     *        request.auth.uid == null
     * @deny (get) User with ID 'user456' tries to read message without being a member.
     *        request.auth.uid == 'user456' and resource.data.members[request.auth.uid] == null
     * @principle Enforces document ownership for writes. Restricts access to members only.
     */
    match /messages/{messageId} {
      function isMember() {
        return resource.data.members[request.auth.uid] == true;
      }
       function isExistingMember() {
        return request.auth.uid != null && isMember() && resource != null;
      }
      allow get, list: if request.auth.uid != null && isMember();
      allow create: if request.auth.uid != null;
      allow update: if isExistingMember();
      allow delete: if isExistingMember();
    }

    /**
     * @description Secures subscription information for each user.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create) User with ID 'user123' creates a subscription.
     *        request.auth.uid == 'user123'
     * @allow (get) User with ID 'user123' reads their subscription.
     *        request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their subscription.
     *        request.auth.uid == 'user123'
     * @allow (delete) User with ID 'user123' deletes their subscription.
     *        request.auth.uid == 'user123'
     * @deny (create) User with ID 'user456' tries to create a subscription for 'user123'.
     *        request.auth.uid == 'user456'
     * @deny (get) User with ID 'user456' tries to read subscription of 'user123'.
     *        request.auth.uid == 'user456'
     * @principle Enforces document ownership for writes. Restricts access to a user's own data.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores all available therapies and services. Publicly readable.
     * @path /services/{serviceId}
     * @allow (get) Any user can read a service.
     *        true
     * @allow (list) Any user can list services.
     *        true
     * @deny (create) No user can create a service.
     *        false
     * @deny (update) No user can update a service.
     *        false
     * @deny (delete) No user can delete a service.
     *        false
     * @principle Public read access. Owner-only writes (not implemented in this prototype due to missing owner field).
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Stores VIP subscription plan details. Publicly readable.
     * @path /vipPlans/{planId}
     * @allow (get) Any user can read a VIP plan.
     *        true
     * @allow (list) Any user can list VIP plans.
     *        true
     * @deny (create) No user can create a VIP plan.
     *        false
     * @deny (update) No user can update a VIP plan.
     *        false
     * @deny (delete) No user can delete a VIP plan.
     *        false
     * @principle Public read access. Owner-only writes (not implemented in this prototype due to missing owner field).
     */
    match /vipPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}