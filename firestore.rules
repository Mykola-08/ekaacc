/**
 * @fileOverview Firestore Security Rules for EKA Account system.
 *
 * Core Philosophy:
 * This ruleset implements a hybrid security model, primarily based on user-ownership and shared access, optimized for performance and queryability.
 *
 * Data Structure:
 * - User profiles and their associated data (sessions, reports, subscriptions) are nested under `/users/{userId}`.
 * - Donations and Messages are stored in top-level collections with denormalized member lists for efficient shared access control.
 * - Services and VipPlans are stored in top-level collections and are publicly readable.
 *
 * Key Security Decisions:
 * - User data is strictly controlled by the user (or admin-level roles, if implemented).
 * - `list` operations on user-scoped subcollections are generally allowed for the owner.
 * - Public read access is granted to the `services` and `vipPlans` collections.
 * - Denormalization is used to avoid costly `get()` calls, improving performance.
 *
 * Denormalization for Authorization:
 * - The `donations` and `messages` collections include a `members` map that contains both the donor/receiver and sender/receiver, respectively, allowing for authorization checks without additional reads.
 *
 * Structural Segregation:
 * - User-private data is stored under the `/users/{userId}` path, while public/shared data resides in top-level collections, streamlining access control for list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) - If the user's auth UID matches the userId.
     * @allow (get, list, update, delete) - If the user is the owner (userId matches auth UID).
     * @deny (create) - If the user's auth UID does not match the userId.
     * @deny (update, delete) - If the user is not the owner.
     * @principle Enforces document ownership for writes and path-based ownership.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to therapy sessions for each user.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create, get, list, update, delete) - If the user is the owner (userId matches auth UID).
     * @deny (create, get, list, update, delete) - If the user is not the owner.
     * @principle Enforces document ownership and validates relational integrity.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to donation data, leveraging a 'members' map for authorization.
     * @path /donations/{donationId}
     * @allow (get, list) - If the user is a donor or receiver (request.auth.uid is in resource.data.members).
     * @allow (create, update, delete) - if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @deny (create, update, delete) - Always deny writes, owner validation is not implemented.
     * @principle Enforces shared access and requires membership for read access.
     */
    match /donations/{donationId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isMember(members) {
          return isSignedIn() && request.auth.uid in members;
      }

      allow get: if isMember(resource.data.members);
      allow list: if isMember(resource.data.members);
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to reports for each user, allowing the user and their therapist to access them.
     * @path /users/{userId}/reports/{reportId}
     * @allow (get, list, create, update, delete) - If the user is the owner (userId matches auth UID).
     * @deny (get, list, create, update, delete) - If the user is not the owner.
     * @principle Enforces document ownership and validates relational integrity.
     */
    match /users/{userId}/reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }
    
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to messages, leveraging a 'members' map for authorization.
     * @path /messages/{messageId}
     * @allow (get, list) - If the user is a sender or receiver (request.auth.uid is in resource.data.members).
     * @deny (create, update, delete) - Always deny writes, owner validation is not implemented.
     * @principle Enforces shared access and requires membership for read access.
     */
    match /messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isMember(members) {
          return isSignedIn() && request.auth.uid in members;
      }
      allow get: if isMember(resource.data.members);
      allow list: if isMember(resource.data.members);
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to subscription information for each user.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create, get, list, update, delete) - If the user is the owner (userId matches auth UID).
     * @deny (create, get, list, update, delete) - If the user is not the owner.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to all available therapies and services.
     * @path /services/{serviceId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - Always deny writes, owner validation is not implemented.
     * @principle Provides public read access while restricting write access.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to VIP subscription plan details.
     * @path /vipPlans/{planId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - Always deny writes, owner validation is not implemented.
     * @principle Provides public read access while restricting write access.
     */
    match /vipPlans/{planId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}