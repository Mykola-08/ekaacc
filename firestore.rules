/**
 * @file Firebase Security Rules for EKA Account system.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data while allowing public read access to certain collections like `therapies` and `plans`.
 * Data crucial for authorization is denormalized to minimize reads.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only by the user themselves.
 * - /users/{userId}/sessions/{sessionId}: Therapy sessions, accessible by the user and their therapist.
 * - /donations/{donationId}: Donations, accessible by the donor and receiver.
 * - /users/{userId}/reports/{reportId}: Reports, accessible by the user and their therapist.
 * - /messages/{messageId}: Messages, accessible by the sender and receiver.
 * - /users/{userId}/subscriptions/{subscriptionId}: Subscriptions, accessible only by the user.
 * - /therapies/{therapyId}: Publicly readable list of available therapies.
 * - /plans/{planId}: Publicly readable list of available subscription plans.
 *
 * Key Security Decisions:
 * - Public listing is enabled for `therapies` and `plans` to allow all users to view available services and plans.
 * - All user-specific data is nested under `/users/{userId}` to simplify ownership checks.
 * - Data required for authorization (e.g., donorId, receiverId in donations) is denormalized into a `members` map on the document to avoid costly `get()` calls.
 * - Write access to user-owned data is restricted to the authenticated user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to manage their own profiles.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user_abc' can create their profile with ID 'user_abc'.
     * @allow (get, update, delete) - User with UID 'user_abc' can access and modify their profile.
     * @deny (create) - User with UID 'user_abc' cannot create a profile with ID 'user_xyz'.
     * @deny (get, update, delete) - User with UID 'user_xyz' cannot access the profile of user 'user_abc'.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows users and their therapists to manage therapy sessions.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create, get, update, delete) - User with UID 'user_abc' can manage their own sessions.
     * @deny (create, get, update, delete) - User with UID 'user_xyz' cannot access sessions of user 'user_abc'.
     * @principle Enforces document ownership and restricts access to user-specific data.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

       function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows donors and receivers to manage donation data.
     * @path /donations/{donationId}
     * @allow (create, get, update, delete) - User with UID 'user_abc' can manage donations where they are the donor or receiver.
     * @deny (create, get, update, delete) - User with UID 'user_xyz' cannot access donations where they are not involved.
     * @principle Enforces access based on membership (donor/receiver) and prevents unauthorized modification.
     */
    match /donations/{donationId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.donorId == request.auth.uid || request.resource.data.receiverId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    /**
     * @description Allows users and their therapists to manage reports.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create, get, update, delete) - User with UID 'user_abc' can manage their own reports or if they are the therapist of the patient.
     * @deny (create, get, update, delete) - User with UID 'user_xyz' cannot access reports of user 'user_abc' unless they are the assigned therapist.
     * @principle Enforces document ownership and allows access for therapists.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && (isOwner(userId) || resource.data.therapistId == request.auth.uid);
      allow list: if false;
      allow create: if isSignedIn() && (isOwner(userId) || request.resource.data.therapistId == request.auth.uid);
      allow update: if isSignedIn() && (isOwner(userId) || resource.data.therapistId == request.auth.uid);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows senders and receivers to manage messages.
     * @path /messages/{messageId}
     * @allow (create, get, update, delete) - User with UID 'user_abc' can manage messages where they are the sender or receiver.
     * @deny (create, get, update, delete) - User with UID 'user_xyz' cannot access messages where they are not involved.
     * @principle Enforces access based on membership (sender/receiver) and prevents unauthorized modification.
     */
    match /messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow list: if false;
      allow create: if isSignedIn() && (request.resource.data.senderId == request.auth.uid || request.resource.data.receiverId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    /**
     * @description Allows users to manage their own subscriptions.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create, get, update, delete) - User with UID 'user_abc' can manage their own subscriptions.
     * @deny (create, get, update, delete) - User with UID 'user_xyz' cannot access subscriptions of user 'user_abc'.
     * @principle Enforces document ownership and restricts access to user-specific data.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows anyone to read the list of available therapies.
     * @path /therapies/{therapyId}
     * @allow (get, list) - Any user, authenticated or not, can view the list of available therapies.
     * @deny (create, update, delete) - No user can create, update, or delete therapy entries.
     * @principle Provides public read access with restricted write access.
     */
    match /therapies/{therapyId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read the list of available plans.
     * @path /plans/{planId}
     * @allow (get, list) - Any user, authenticated or not, can view the list of available plans.
     * @deny (create, update, delete) - No user can create, update, or delete plan entries.
     * @principle Provides public read access with restricted write access.
     */
    match /plans/{planId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}