/**
 * @file Firebase Security Rules for EKA Account Firestore Database
 *
 * @corePhilosophy This ruleset enforces a strict user-ownership model for user profiles and related data,
 *                 combined with role-based access for collaborative scenarios (therapists/users) and
 *                 denormalized membership checks for shared documents (donations, messages). It prioritizes
 *                 authorization independence and avoids costly `get()` calls by denormalizing authorization
 *                 data directly into the documents.
 *
 * @dataStructure The database is organized hierarchically:
 *                 - /users/{userId}: User profile information.
 *                 - /users/{userId}/sessions/{sessionId}: Therapy sessions for a user.
 *                 - /donations/{donationId}: Donation data, with denormalized donor/receiver information.
 *                 - /users/{userId}/reports/{reportId}: Reports related to a user.
 *                 - /messages/{messageId}: Messages with denormalized sender/receiver information.
 *                 - /users/{userId}/subscriptions/{subscriptionId}: Subscription data for a user.
 *
 * @keySecurityDecisions - User profiles and associated data are only accessible by the user themselves.
 *                       - Therapists can access reports and sessions of their patients.
 *                       - Donations and Messages use denormalized `members` maps for efficient authorization checks.
 *                       - Listing of user profiles is disallowed to prevent data scraping.
 *
 * @denormalizationForAuthorization The `members` map in `/donations/{donationId}` and `/messages/{messageId}`
 *                                 documents stores the `donorId`/`receiverId` and `senderId`/`receiverId`
 *                                 respectively, allowing for efficient membership checks without needing
 *                                 additional reads.
 *                                 Reports store the `therapistId` to allow therapists to access reports they create for their patients.
 *
 * @structuralSegregation User-specific data is stored under the `/users/{userId}` path, while shared or public data
 *                        resides in top-level collections like `/donations` and `/messages`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to user profiles, enforcing strict ownership.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile if request.auth.uid == 'user123'.
     * @allow (get, update, delete) User with ID 'user123' can get, update, and delete their profile if request.auth.uid == 'user123'.
     * @deny (create) User with ID 'user456' cannot create a profile with ID 'user123'.
     * @deny (get, update, delete) User with ID 'user456' cannot get, update, and delete the profile of user 'user123'.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing of all user profiles

      allow create: if isOwner(userId) && request.resource.data.id == userId; // Enforce path consistency on create.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id; // Enforce immutability of userId.
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows access to therapy sessions for a user, enforcing ownership and therapist access.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create) User 'user123' can create a session under their ID if request.auth.uid == 'user123'.
     * @allow (get, update, delete) User 'user123' can access their own session data.
     * @allow (get, update, delete) Therapist 'therapist456' can access sessions where session.therapistId == 'therapist456'.
     * @deny (create) User 'user456' cannot create a session under user 'user123'.
     * @deny (get, update, delete) User 'user456' cannot access sessions of user 'user123' unless they are the therapist.
     * @principle Enforces document ownership and allows therapist access to patient data.
     */
    match /users/{userId}/sessions/{sessionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isTherapist(therapistId) {
          return request.auth.uid == therapistId;
      }

      function isExistingOwnerOrTherapist(userId, therapistId) {
        return (isOwner(userId) || isTherapist(therapistId)) && resource != null;
      }

      allow get: if isOwner(userId) || isTherapist(resource.data.therapistId);
      allow list: if isOwner(userId); // Allow the owner to list their own sessions.

      allow create: if isOwner(userId);
      allow update: if isExistingOwnerOrTherapist(userId, resource.data.therapistId);
      allow delete: if isExistingOwnerOrTherapist(userId, resource.data.therapistId);
    }

    /**
     * @description Allows access to donation data based on membership in the 'members' map (donorId or receiverId).
     * @path /donations/{donationId}
     * @allow (create) Any authenticated user can create a donation. Requires schema update for ownership validation.
     * @allow (get, list) Anyone can get and list donations.
     * @deny (update, delete) Updates and deletes are disallowed without membership.
     * @principle Enforces membership-based access for shared documents.
     */
    match /donations/{donationId} {
      function isMember() {
        return request.auth.uid != null && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      }

      function isExistingMember() {
        return isMember() && resource != null;
      }

      allow get, list: if true; // Public read access.

      allow create: if request.auth.uid != null; // TODO: Add ownership validation once the schema is updated with an ownership field.
      allow update: if isExistingMember();
      allow delete: if isExistingMember();
    }

    /**
     * @description Allows access to reports for a user, enforcing ownership and therapist access.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User 'user123' can create a report under their ID if request.auth.uid == 'user123'.
     * @allow (get, update, delete) User 'user123' can access their own reports.
     * @allow (get, update, delete) Therapist 'therapist456' can access reports where report.therapistId == 'therapist456'.
     * @deny (create) User 'user456' cannot create a report under user 'user123'.
     * @deny (get, update, delete) User 'user456' cannot access reports of user 'user123' unless they are the therapist.
     * @principle Enforces document ownership and allows therapist access to patient data.
     */
    match /users/{userId}/reports/{reportId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isTherapist(therapistId) {
          return request.auth.uid == therapistId;
      }

      function isExistingOwnerOrTherapist(userId, therapistId) {
        return (isOwner(userId) || isTherapist(therapistId)) && resource != null;
      }

      allow get: if isOwner(userId) || isTherapist(resource.data.therapistId);
      allow list: if isOwner(userId); // Allow the owner to list their own reports.

      allow create: if isOwner(userId);
      allow update: if isExistingOwnerOrTherapist(userId, resource.data.therapistId);
      allow delete: if isExistingOwnerOrTherapist(userId, resource.data.therapistId);
    }

    /**
     * @description Allows access to messages based on membership in the 'members' map (senderId or receiverId).
     * @path /messages/{messageId}
     * @allow (create) Any authenticated user can create a message. Requires schema update for ownership validation.
     * @allow (get, list) Anyone can get and list messages.
     * @deny (update, delete) Updates and deletes are disallowed without membership.
     * @principle Enforces membership-based access for shared documents.
     */
    match /messages/{messageId} {
      function isMember() {
        return request.auth.uid != null && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      }

      function isExistingMember() {
        return isMember() && resource != null;
      }

      allow get, list: if true; // Public read access.

      allow create: if request.auth.uid != null; // TODO: Add ownership validation once the schema is updated with an ownership field.
      allow update: if isExistingMember();
      allow delete: if isExistingMember();
    }

    /**
     * @description Allows access to subscription information for a user, enforcing strict ownership.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create) User 'user123' can create a subscription under their ID if request.auth.uid == 'user123'.
     * @allow (get, update, delete) User 'user123' can get, update, and delete their own subscription.
     * @deny (create) User 'user456' cannot create a subscription under user 'user123'.
     * @deny (get, update, delete) User 'user456' cannot access subscriptions of user 'user123'.
     * @principle Enforces document ownership and restricts access to a user's own data tree.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}