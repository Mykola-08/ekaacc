rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isTherapist() { return isSignedIn() && request.auth.token.therapist == true; }
    function isOwner(userId) { return isSignedIn() && uid() == userId; }

    // ---- DEV-ONLY mock superuser (never set in prod) ----
    function isDevMock() {
      return isSignedIn()
        && request.auth.token.env == 'dev'
        && request.auth.token.email == 'demo@ekaacc.com'
        && request.auth.token.mock_super == true;
    }
    function isAdminLike() { return isAdmin() || isDevMock(); }

    // ---- USERS (profile) ----
    match /users/{userId} {
      // Public samples only
      allow get, list: if userId in ['sample_user','therapist_sample','donor_sample'];

      // Real users
      allow get: if isOwner(userId) || isAdminLike();
      allow list: if false; // no user directory

      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdminLike())
        // block privilege escalation from client
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['roles','admin','therapist','claims','env','mock_super']);
      allow delete: if isOwner(userId) || isAdminLike();
    }

    // ---- SESSIONS (user + assigned therapist) ----
    // Doc must include: userId, therapistId, and any safe fields.
    match /users/{userId}/sessions/{sessionId} {
      allow create: if (isOwner(userId) || isAdminLike())
        && request.resource.data.userId == userId;

      allow get: if isOwner(userId)
        || (isTherapist() && resource.data.therapistId == uid())
        || isAdminLike();

      allow list: if isOwner(userId)
        || (isTherapist() && request.query.limit <= 50)
        || isDevMock();

      allow update, delete: if (isOwner(userId) && resource.data.userId == userId)
        || (isTherapist() && resource.data.therapistId == uid())
        || isAdminLike();
    }

    // ---- REPORTS (user + creating therapist) ----
    // Doc must include: userId, therapistId.
    match /users/{userId}/reports/{reportId} {
      allow create: if isOwner(userId)
        || (isTherapist()
            && request.resource.data.userId == userId
            && request.resource.data.therapistId == uid())
        || isAdminLike();

      allow get: if isOwner(userId)
        || (isTherapist() && resource.data.therapistId == uid())
        || isAdminLike();

      allow list: if isOwner(userId)
        || (isTherapist() && request.query.limit <= 50)
        || isDevMock();

      allow update, delete: if (isOwner(userId) && resource.data.userId == userId)
        || (isTherapist() && resource.data.therapistId == uid())
        || isAdminLike();
    }

    // ---- SUBSCRIPTIONS (owner) ----
    // Doc must include: userId.
    match /users/{userId}/subscriptions/{subscriptionId} {
      allow create: if (isOwner(userId) || isAdminLike())
        && request.resource.data.userId == userId;
      allow get, list: if isOwner(userId) || isAdminLike();
      allow update, delete: if isOwner(userId) || isAdminLike();
    }

    // ---- MESSAGES (member-only) ----
    // Doc must include: senderId, members: { [uid]: true, ... }
    match /messages/{messageId} {
      function isMember() { return isSignedIn() && resource.data.members[uid()] == true; }
      function isSender() { return isSignedIn() && resource.data.senderId == uid(); }

      allow create: if isSignedIn()
        && request.resource.data.senderId == uid()
        && request.resource.data.members[uid()] == true
        || isDevMock();

      allow get: if isMember() || isAdminLike();
      // Client must query with where('members.<uid>', '==', true)
      allow list: if (isSignedIn() && request.query.limit <= 50) || isDevMock();

      allow update, delete: if isSender() || isAdminLike();
    }

    // ---- DONATIONS (donor or receiver) ----
    // Doc must include: donorId, receiverId, members: { donorUid: true, receiverUid: true }
    match /donations/{donationId} {
      function isDonationMember() { return isSignedIn() && resource.data.members[uid()] == true; }

      allow create: if isSignedIn()
        && request.resource.data.donorId == uid()
        && request.resource.data.members[uid()] == true
        || isDevMock();

      allow get: if isDonationMember() || isAdminLike();
      // Client must query with where('members.<uid>', '==', true)
      allow list: if (isSignedIn() && request.query.limit <= 50) || isDevMock();

      // Only donor can change/cancel; admin-like can too
      allow update, delete: if (isDonationMember() && uid() == resource.data.donorId) || isAdminLike();
    }

    // ---- PUBLIC CATALOGS ----
    match /services/{serviceId} {
      allow get, list: if true;                  // public read
      allow create, update, delete: if isAdminLike(); // write via Admin or dev-mock
    }
    match /vipPlans/{planId} {
      allow get, list: if true;                  
      allow create, update, delete: if isAdminLike();
    }

    // ---- DENY EVERYTHING ELSE ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
