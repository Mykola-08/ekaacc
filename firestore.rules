/**
 * @file Firebase Security Rules for EKA Account Firestore Database
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data stored
 * under `/users/{userId}`. Collaborative access (e.g., therapist/client) is managed
 * through denormalized fields like `therapistId` or `members` maps directly within the documents.
 * Public data (e.g., available services) resides in top-level collections.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only by the user or an admin.
 * - /users/{userId}/sessions/{sessionId}: Therapy sessions, accessible by the user or their therapist.
 * - /donations/{donationId}: Donation records, with 'donorId' and 'receiverId' in a 'members' map for authorization.
 * - /users/{userId}/reports/{reportId}: Reports, accessible by the user or the creating therapist.
 * - /messages/{messageId}: Messages, with 'senderId' and 'receiverId' in a 'members' map for authorization.
 * - /users/{userId}/subscriptions/{subscriptionId}: Subscription details for each user.
 * - /services/{serviceId}: Publicly available therapy services.
 * - /vipPlans/{planId}: Publicly available VIP subscription plans.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed to protect privacy.
 * - Data required for authorization is denormalized onto the documents to avoid costly `get()` calls.
 * - Top-level collections like `/services` and `/vipPlans` are publicly readable.
 *
 * Denormalization for Authorization:
 * - The `donorId` and `receiverId` are denormalized to the `members` map in `/donations/{donationId}`.
 * - The `senderId` and `receiverId` are denormalized to the `members` map in `/messages/{messageId}`.
 * - The `therapistId` field exists within the report document under `/users/{userId}/reports/{reportId}`.
 *
 * Structural Segregation:
 * - User-specific data is stored under `/users/{userId}` to ensure privacy and ownership.
 * - Public data like services and VIP plans are in top-level collections for easy access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user ID matches the user ID in the resource data.
     */
    function isResourceOwner(resourceUserId) {
      return isSignedIn() && request.auth.uid == resourceUserId;
    }

    /**
     * @description Checks if the authenticated user ID matches the existing resource's user ID.
     */
    function isExistingOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user ID is present in the members map.
     */
    function isMember(members) {
      return isSignedIn() && members[request.auth.uid] != null;
    }
    
    /**
     * @description Checks if the authenticated user ID is present in the members map with 'owner' role.
     */
    function isOwnerMember(members) {
      return isSignedIn() && members[request.auth.uid] == 'owner';
    }

    /**
     * @description Security rules for /users/{userId} documents.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their profile.
     *       request.auth.uid == 'user123' and request.resource.data.id == 'user123'
     * @allow (get) User with ID 'user123' reads their profile.
     *       request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their profile.
     *       request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create a profile for 'user456'.
     *       request.auth.uid == 'user123' and request.resource.data.id == 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Security rules for /users/{userId}/sessions/{sessionId} documents.
     * @path /users/{userId}/sessions/{sessionId}
     * @allow (create) User with ID 'user123' creates a session in their profile.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user123'
     * @allow (get) User with ID 'user123' reads their session data.
     *       request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their session data.
     *       request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create a session for 'user456'.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user456'
     * @principle Restricts access to a user's own session data.
     */
    match /users/{userId}/sessions/{sessionId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Security rules for /donations/{donationId} documents.
     * @path /donations/{donationId}
     * @allow (create) User with ID 'user123' creates a donation.
     *       request.auth.uid == 'user123' and request.resource.data.members[request.auth.uid] != null
     * @allow (get) User with ID 'user123' reads donation data where they are a member.
     *       request.auth.uid == 'user123' and resource.data.members['user123'] != null
     * @allow (update) User with ID 'user123' updates donation data where they are an owner.
     *       request.auth.uid == 'user123' and resource.data.members['user123'] == 'owner'
     * @deny (create) User with ID 'user123' tries to create a donation where they are not a member.
     *       request.auth.uid == 'user123' and request.resource.data.members['user123'] == null
     * @principle Enforces membership-based access control for donations.
     */
    match /donations/{donationId} {
      allow get: if isMember(resource.data.members);
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] != null;
      allow update: if isMember(resource.data.members);
      allow delete: if isOwnerMember(resource.data.members);
    }

    /**
     * @description Security rules for /users/{userId}/reports/{reportId} documents.
     * @path /users/{userId}/reports/{reportId}
     * @allow (create) User with ID 'user123' creates a report in their profile.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user123'
     * @allow (get) User with ID 'user123' reads their report data.
     *       request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their report data.
     *       request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create a report for 'user456'.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user456'
     * @principle Restricts access to a user's own reports data.
     */
    match /users/{userId}/reports/{reportId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Security rules for /messages/{messageId} documents.
     * @path /messages/{messageId}
     * @allow (create) User with ID 'user123' creates a message.
     *       request.auth.uid == 'user123' and request.resource.data.members[request.auth.uid] != null
     * @allow (get) User with ID 'user123' reads message data where they are a member.
     *       request.auth.uid == 'user123' and resource.data.members['user123'] != null
     * @allow (update) User with ID 'user123' updates message data where they are an owner.
     *       request.auth.uid == 'user123' and resource.data.members['user123'] == 'owner'
     * @deny (create) User with ID 'user123' tries to create a message where they are not a member.
     *       request.auth.uid == 'user123' and request.resource.data.members['user123'] == null
     * @principle Enforces membership-based access control for messages.
     */
    match /messages/{messageId} {
      allow get: if isMember(resource.data.members);
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] != null;
      allow update: if isMember(resource.data.members);
      allow delete: if isOwnerMember(resource.data.members);
    }

    /**
     * @description Security rules for /users/{userId}/subscriptions/{subscriptionId} documents.
     * @path /users/{userId}/subscriptions/{subscriptionId}
     * @allow (create) User with ID 'user123' creates a subscription in their profile.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user123'
     * @allow (get) User with ID 'user123' reads their subscription data.
     *       request.auth.uid == 'user123'
     * @allow (update) User with ID 'user123' updates their subscription data.
     *       request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create a subscription for 'user456'.
     *       request.auth.uid == 'user123' and request.resource.data.userId == 'user456'
     * @principle Restricts access to a user's own subscription data.
     */
    match /users/{userId}/subscriptions/{subscriptionId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Security rules for /services/{serviceId} documents.
     * @path /services/{serviceId}
     * @allow (get) Any user can get service data.
     *       true
     * @allow (list) Any user can list service data.
     *       true
     * @deny (create) No one can create service data.
     *       false
     * @deny (update) No one can update service data.
     *       false
     * @deny (delete) No one can delete service data.
     *       false
     * @principle Allows public read access to service information.
     */
    match /services/{serviceId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Security rules for /vipPlans/{planId} documents.
     * @path /vipPlans/{planId}
     * @allow (get) Any user can get VIP plan data.
     *       true
     * @allow (list) Any user can list VIP plan data.
     *       true
     * @deny (create) No one can create VIP plan data.
     *       false
     * @deny (update) No one can update VIP plan data.
     *       false
     * @deny (delete) No one can delete VIP plan data.
     *       false
     * @principle Allows public read access to VIP plan information.
     */
    match /vipPlans/{planId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}