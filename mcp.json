{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "mcp_square_api": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.squareup.com/sse"
      ]
    },
    "auth0": {
      "command": "node",
      "args": ["./mcp-auth0/index.js"]
    }
  }
}
