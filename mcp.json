{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "mcp_square_api": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.squareup.com/sse"
      ]
    },
    "statsig-local": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://api.statsig.com/v1/mcp",
        "--header",
        "statsig-api-key:${AUTH_TOKEN}"
      ],
      "env": {
        "AUTH_TOKEN": "${STATSIG_API_KEY}"  
      }
    }
  }
}
