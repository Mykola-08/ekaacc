{
  "name": "ekaacc-monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/booking-app",
    "apps/seowebsite",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "security:audit": "npm audit --audit-level=high || echo 'Audit completed with findings'",
    "security:secrets": "npx gitleaks detect --no-banner --redact || echo 'Gitleaks scan finished'",
    "ci": "turbo run lint typecheck",
    "prepare": "husky || echo 'Husky not installed'"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "turbo": "^2.7.3"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^25.0.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.25.0",
    "pg": "^8.16.3",
    "stripe": "^20.1.2",
    "tailwind-merge": "^3.4.0",
    "telegraf": "^4.16.3",
    "typescript": "^5.9.3",
    "vercel": "^50.1.6",
    "zod": "^4.3.5"
  }
}
