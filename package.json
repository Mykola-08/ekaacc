{
  "name": "ekaacc-monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/booking-app",
    "apps/seowebsite",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "security:audit": "npm audit --audit-level=high || echo 'Audit completed with findings'",
    "security:secrets": "npx gitleaks detect --no-banner --redact || echo 'Gitleaks scan finished'",
    "ci": "turbo run lint typecheck",
    "prepare": "husky || echo 'Husky not installed'"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "shadcn": "^3.8.2",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vercel": "^50.4.5"
  },
  "overrides": {
    "@vercel/node": {
      "path-to-regexp": "^6.3.0"
    },
    "@vercel/remix-builder": {
      "path-to-regexp": "^6.3.0"
    },
    "undici": "^6.23.0",
    "@vercel/blob": {
      "undici": "^6.23.0"
    },
    "diff": "^8.0.3",
    "esbuild": "^0.25.0",
    "tar": "^7.5.3"
  },
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^25.0.9",
    "@vercel/blob": "^2.0.0",
    "clsx": "^2.1.1",
    "motion": "^12.29.2",
    "pg": "^8.17.1",
    "stripe": "^20.2.0"
  }
}
