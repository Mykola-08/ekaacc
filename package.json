{
  "name": "ekaacc-monorepo",
  "private": true,
  "workspaces": [
    "apps/admin",
    "apps/booking",
    "apps/docs",
    "apps/legal",
    "apps/marketing",
    "apps/therapist",
    "apps/web",
    "apps/auth",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:ui": "turbo run test:e2e:ui",
    "test:e2e:debug": "turbo run test:e2e:debug",
    "test:load": "turbo run test:load",
    "test:load:api": "turbo run test:load:api",
    "test:load:spike": "turbo run test:load:spike",
    "test:vercel": "turbo run test:vercel",
    "test:vercel:env": "turbo run test:vercel:env",
    "test:all": "turbo run test && turbo run test:e2e",
    "verify:auth0": "turbo run verify:auth0",
    "verify:auth0:connections": "turbo run verify:auth0:connections",
    "security:audit": "npm audit --audit-level=high || echo 'Audit completed with findings'",
    "security:secrets": "npx gitleaks detect --no-banner --redact || echo 'Gitleaks scan finished'",
    "check:resend": "turbo run check:resend",
    "test:resend": "turbo run test:resend",
    "ci": "turbo run lint typecheck test",
    "prepare": "husky install || echo 'Husky not installed'"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "nextra": "^4.6.0",
    "nextra-theme-docs": "^4.6.0",
    "next-themes": "0.3.0",
    "@headlessui/react": "2.2.0",
    "@floating-ui/react-dom": "2.1.0",
    "@react-aria/focus": "*",
    "@react-aria/interactions": "*",
    "@react-aria/utils": "3.0.0",
    "@react-aria/ssr": "3.0.0",
    "@tanstack/react-virtual": "*",
    "use-sync-external-store": "1.2.0",
    "whatwg-fetch": "^3.6.20"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.84.0"
  }
}
