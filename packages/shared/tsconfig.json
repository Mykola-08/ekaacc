{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "es2019",
        "lib": [
            "es2019",
            "dom"
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "strict": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}