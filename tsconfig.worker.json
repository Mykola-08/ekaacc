{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/worker/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs",
    "api/**/*.ts",
    "supabase/functions/**/*.ts",
    ".prettierrc.js",
    "tailwind.config.ts",
    "postcss.config.js",
    "next.config.mjs"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
