{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "turbo run build --filter=web",
  "devCommand": "turbo run dev --filter=web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
